# Rename this file to .env and fill with your settings

# Data for the backend used to send emails via Gmail. You can get your password here: https://myaccount.google.com/apppasswords.
# Two-factor authentication must be enabled on the account.
EMAIL_HOST_USER=xxx@gmail.com
EMAIL_HOST_PASSWORD='xxxx xxxx xxxx xxxx'
# Enables email verification during user registration
EMAIL_CONFIRMATION_ENABLED=True
# Enables automatic generation of AI responses to questions from the bot account
AI_HELPER_ENABLED=True
# Bot account username
AI_HELPER_USERNAME='AI Helper'
# Data for using Cloudflare AI Workers. Learn more here: https://developers.cloudflare.com/ai-gateway/usage/providers/workersai/
CLOUDFLARE_API_KEY=XXX
CLOUDFLARE_ACCOUNT_ID=XXX
# Model name for text generation. List of available models: https://developers.cloudflare.com/workers-ai/models
CLOUDFLARE_MODEL_NAME=@cf/google/gemma-3-12b-it
# API key for using the IMGBB API. Get the key here: https://api.imgbb.com. IMGBB is used to save user avatars
IMGBB_API_KEY=XXX
# Python defines the following log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Data for connection to the PostgreSQL database
DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=user
DB_PASSWORD=password
# A list of strings representing the host/domain names that this Django site can serve
ALLOWED_HOSTS='localhost 127.0.0.1 [::1]'
# Generated by command: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=XXX
# A boolean that turns on/off debug mode
DEBUG=False
# The zoneinfo.available_timezones() function returns a set of all available time zone keys on your system
TIME_ZONE=Europe/Kyiv